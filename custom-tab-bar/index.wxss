/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: flex-start;
  padding-top: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.tab-item-active .tab-text {
  color: #c20000;
  font-weight: bold;
}
