<!--pages/team/team.wxml-->

<!-- 开屏动画 -->
<view wx:if="{{showSplash}}" class="splash-overlay {{splashMeltOut ? 'splash-melt' : ''}}" style="padding-bottom: {{splashNavBarHeight}}px">
  <image wx:if="{{splashLogoUrl}}" class="splash-logo {{splashLogoVisible ? 'splash-logo-in' : ''}} {{splashHeartbeat ? 'splash-heartbeat' : ''}}" src="{{splashLogoUrl}}" mode="aspectFit" />
</view>

<!-- 顶部固定 Tab 栏 -->
<view class="tabs-fixed-wrapper">
  <!-- 默认态：搜索图标 + tab 滚动区 + 展开按钮 -->
  <view wx:if="{{!isSearching}}" class="tabs-row">
    <view class="search-icon-btn" bindtap="onSearchOpen">
      <text class="search-icon-text">🔍</text>
    </view>
    <scroll-view class="tabs-container" scroll-x="{{true}}" show-scrollbar="{{false}}" scroll-with-animation="{{true}}" scroll-left="{{tabScrollLeft}}" bindscroll="onTabsScroll">
      <view class="tabs">
        <view
          class="tab-item {{activeTab === item ? 'tab-active' : ''}}"
          wx:for="{{visibleTabs}}"
          wx:key="index"
          bindtap="onTabChange"
          data-tab="{{item}}"
        >
          <text class="tab-text">{{item}}</text>
        </view>
        <!-- 展开箭头：在最后一个 tab 后面，滑动才能看到 -->
        <view wx:if="{{hasMoreTabs}}" class="expand-btn" catchtap="onToggleTagPanel">
          <text class="expand-icon">{{showTagPanel ? '▲' : '▼'}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 搜索态：← + 搜索框 -->
  <view wx:else class="tabs-row">
    <view class="search-icon-btn" bindtap="onSearchClose">
      <text class="search-back-icon-text">←</text>
    </view>
    <view class="search-box">
      <text class="search-tab-label">{{activeTab}}</text>
      <text class="search-divider">|</text>
      <input
        class="search-input"
        placeholder="{{searchPlaceholder}}"
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
        value="{{searchQuery}}"
        focus="{{isSearching}}"
      />
    </view>
  </view>

  <!-- 展开的全部标签面板 -->
  <view class="tag-panel {{showTagPanel ? 'tag-panel-show' : ''}}" catchtap="onTagPanelStop">
    <view class="tag-list">
      <view
        class="tag-item {{activeTab === item ? 'tag-item-active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="index"
        bindtap="onTabChange"
        data-tab="{{item}}"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>
</view>

<view class="team-container" bindtap="onContainerTap">
  <!-- 团队统计 -->
  <view class="team-stats-section">
    <view class="team-stats-content {{!isCofounder && identityChecked ? 'team-stats-content-no-button' : ''}}">
      <view class="team-stat-item">
        <text class="team-stat-number">{{teamCount}}</text>
        <text class="team-stat-label">联合创始人</text>
      </view>
      <view class="team-stat-item team-stat-border">
        <text class="team-stat-number">{{totalBadges}}</text>
        <text class="team-stat-label">荣誉徽章</text>
      </view>
      <view class="team-stat-item">
        <text class="team-stat-number">{{uniqueSkills}}</text>
        <text class="team-stat-label">专业技能</text>
      </view>
    </view>

    <image wx:if="{{aiaFooterUrl}}" class="stats-footer-image" src="{{aiaFooterUrl}}" mode="aspectFit"></image>

    <!-- 生成海报按钮（仅联合创始人可见） -->
    <view wx:if="{{!identityChecked || isCofounder}}">
      <!-- 骨架图（身份识别中或logo加载中） -->
      <view class="team-stats-poster-btn-skeleton" wx:if="{{!identityChecked || (isCofounder && !posterBtnLogoLoaded)}}"></view>

      <!-- 实际按钮（联合创始人） -->
      <view class="team-stats-poster-btn {{!isCofounder || !posterBtnLogoLoaded ? 'team-stats-poster-btn-hidden' : ''}}" catchtap="{{isCofounder ? 'onPosterBtnTap' : ''}}">
        <view class="poster-btn-icon-wrapper">
          <image class="poster-btn-icon-img" src="{{shanxinLogoUrl}}" mode="aspectFit" bindload="onPosterBtnLogoLoad"></image>
        </view>
        <text class="poster-btn-text">{{allImagesLoaded ? '生成团队海报' : '头像加载中...'}}</text>
      </view>
    </view>
  </view>

  <!-- 合伙人网格 -->
  <view class="partners-grid">
    <!-- 未完善资料的占位项 -->
    <view wx:if="{{hasIncompleteProfile}}" class="partner-item partner-item-incomplete" bindtap="onIncompleteProfileTap">
      <view class="partner-avatar partner-avatar-incomplete">
        <view class="partner-avatar-placeholder">
          <text class="placeholder-icon">+</text>
        </view>
      </view>
      <view class="partner-info">
        <text class="partner-name">点击完善信息</text>
      </view>
    </view>
    
    <!-- 正常的合伙人列表 -->
    <view class="partner-item {{item.animated ? 'item-animating' : ''}}" style="{{item.animated ? 'animation-delay: ' + (index * 50) + 'ms' : ''}}" wx:for="{{filteredPartners}}" wx:key="employeeId" wx:for-index="index" bindtap="{{item.loaded ? 'onPartnerTap' : ''}}" data-name="{{item.name}}">
      <view class="partner-avatar {{!item.loaded ? 'partner-avatar-loading' : 'partner-avatar-loaded'}}">
        <view class="partner-avatar-img-wrapper">
          <image class="partner-avatar-img {{item.loaded ? 'partner-avatar-img-show' : ''}}" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-name="{{item.name}}"></image>
        </view>
      </view>
      <view class="partner-info">
        <text class="partner-name {{!item.loaded ? 'skeleton-text' : ''}}">{{item.name}}</text>
        <view class="partner-school-container">
          <text class="partner-school {{!item.loaded ? 'skeleton-text' : ''}}" wx:for="{{item.schoolLines}}" wx:key="*this" wx:for-item="line">{{line || '占位'}}</text>
        </view>
        <view class="partner-title-container">
          <text class="partner-title {{!item.loaded ? 'skeleton-text' : ''}}" wx:for="{{item.titleLines}}" wx:key="*this" wx:for-item="line">{{line || '占位'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 团队宣言 -->
  <view class="team-motto-section">
    <view class="motto-icon">
      <text class="iconfont">🤝</text>
    </view>
    <text class="motto-title">善心浙里与您共创丰盛未来！</text>
    <text class="motto-desc">以合作互助的态度实现伙伴完美人生</text>
    <text class="motto-desc">以专业用心的态度锁住客户幸福生活</text>
  </view>
</view>

<!-- 团队海报弹窗 -->
<view class="poster-modal {{showPoster ? 'poster-modal-show' : ''}}" bindtap="onHidePoster">
  <view class="poster-content {{showPoster ? 'poster-content-show' : ''}}" catchtap="onStopPropagation">
    <view class="poster-modal-header">
      <text class="poster-modal-title">团队海报</text>
      <text class="poster-modal-close" bindtap="onHidePoster">✕</text>
    </view>
    <!-- 骨架屏（海报生成中） -->
    <view wx:if="{{posterScrollReady && !posterImage}}" class="poster-image-wrapper">
      <view class="poster-skeleton">
        <view class="poster-skeleton-shimmer"></view>
      </view>
    </view>
    <!-- 真实海报（生成完成后） -->
    <scroll-view wx:if="{{posterScrollReady && posterImage}}" class="poster-scroll-view" scroll-y>
      <view class="poster-image-wrapper">
        <image class="poster-image poster-image-show" src="{{posterImage}}" mode="widthFix" show-menu-by-longpress="{{true}}"></image>
        <!-- 提示文字 -->
        <text class="poster-tip poster-tip-show">长按图片保存到相册</text>
      </view>
    </scroll-view>
  </view>
</view>

<!-- Canvas 用于生成海报 -->
<canvas canvas-id="posterCanvas" class="poster-canvas" style="width: 750px; height: {{canvasHeight}}px;"></canvas>

<!-- Canvas 用于生成分享图 -->
<canvas canvas-id="shareCanvas" class="share-canvas" style="width: 750px; height: 750px;"></canvas>
