<!--pages/team/team.wxml-->
<view class="team-container" bindtap="onContainerTap">
  <!-- 搜索框 -->
  <view class="search-container" catchtap="onSearchTap">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="{{searchPlaceholder}}"
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
        value="{{searchQuery}}"
        focus="{{isApplyMode}}"
      />
    </view>
  </view>

  <!-- 团队统计 -->
  <view class="team-stats-section">
    <view class="team-stats-content">
      <view class="team-stat-item">
        <text class="team-stat-number">{{teamCount}}</text>
        <text class="team-stat-label">联合创始人</text>
      </view>
      <view class="team-stat-item team-stat-border">
        <text class="team-stat-number">{{totalBadges}}</text>
        <text class="team-stat-label">荣誉徽章</text>
      </view>
      <view class="team-stat-item">
        <text class="team-stat-number">{{uniqueSkills}}</text>
        <text class="team-stat-label">专业技能</text>
      </view>
    </view>
    <view class="team-stats-poster-btn {{!isCofounder || !posterBtnLogoLoaded ? 'team-stats-poster-btn-hidden' : ''}}" catchtap="{{isCofounder ? 'onPosterBtnTap' : ''}}">
      <view class="poster-btn-icon">
        <image class="poster-btn-icon-img" src="{{shanxinLogoUrl}}" mode="aspectFit" bindload="onPosterBtnLogoLoad"></image>
      </view>
      <text class="poster-btn-text">{{allImagesLoaded ? '生成团队海报' : '头像加载中...'}}</text>
    </view>
  </view>

  <!-- 合伙人网格 -->
  <view class="partners-grid">
    <view class="partner-item" wx:for="{{filteredPartners}}" wx:key="employeeId" bindtap="onPartnerTap" data-name="{{item.name}}">
      <view class="partner-avatar {{!item.loaded ? 'partner-avatar-loading' : 'partner-avatar-loaded'}}">
        <view class="partner-avatar-img-wrapper">
          <image class="partner-avatar-img {{item.loaded ? 'partner-avatar-img-show' : ''}}" src="{{item.image}}" mode="aspectFill" bindload="onImageLoad" binderror="onImageError" data-name="{{item.name}}"></image>
        </view>
      </view>
      <view class="partner-info">
        <text class="partner-name {{!item.loaded ? 'skeleton-text' : ''}}">{{item.name}}</text>
        <view class="partner-school-container">
          <text class="partner-school {{!item.loaded ? 'skeleton-text' : ''}}" wx:for="{{item.schoolLines}}" wx:key="*this" wx:for-item="line">{{line || '占位'}}</text>
        </view>
        <view class="partner-title-container">
          <text class="partner-title {{!item.loaded ? 'skeleton-text' : ''}}" wx:for="{{item.titleLines}}" wx:key="*this" wx:for-item="line">{{line || '占位'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 团队宣言 -->
  <view class="team-motto-section">
    <view class="motto-icon">
      <text class="iconfont">🤝</text>
    </view>
    <text class="motto-title">善心浙里与您共创丰盛未来！</text>
    <text class="motto-desc">以合作互助的态度实现伙伴完美人生</text>
    <text class="motto-desc">以专业用心的态度锁住客户幸福生活</text>
  </view>

  <!-- 加入团队按钮（仅非合伙人可见） -->
  <view class="join-btn-section" wx:if="{{!isCofounder}}">
    <view class="join-btn" catchtap="onApplyPartner">
      <text class="btn-text">申请加入团队</text>
    </view>
  </view>
</view>

<!-- 团队海报弹窗 -->
<view class="poster-modal {{showPoster ? 'poster-modal-show' : ''}}" bindtap="onHidePoster">
  <view class="poster-content {{showPoster ? 'poster-content-show' : ''}}" catchtap="onStopPropagation">
    <view class="poster-modal-header">
      <text class="poster-modal-title">团队海报</text>
      <text class="poster-modal-close" bindtap="onHidePoster">✕</text>
    </view>
    <scroll-view wx:if="{{posterScrollReady}}" class="poster-scroll-view" scroll-y>
      <view class="poster-image-wrapper">
        <!-- 骨架屏 -->
        <view class="poster-skeleton {{posterImage ? 'poster-skeleton-hide' : ''}}">
          <view class="poster-skeleton-shimmer"></view>
        </view>
        <!-- 真实海报 -->
        <image class="poster-image {{posterImage ? 'poster-image-show' : ''}}" src="{{posterImage}}" mode="widthFix" show-menu-by-longpress="{{true}}"></image>
        <!-- 提示文字（仅在图片显示后出现） -->
        <text class="poster-tip poster-tip-show" wx:if="{{posterImage}}">长按图片保存到相册</text>
      </view>
    </scroll-view>
  </view>
</view>

<!-- Canvas 用于生成海报 -->
<canvas canvas-id="posterCanvas" class="poster-canvas" style="width: 750px; height: {{canvasHeight}}px;"></canvas>

<!-- Canvas 用于生成分享图 -->
<canvas canvas-id="shareCanvas" class="share-canvas" style="width: 750px; height: 750px;"></canvas>
