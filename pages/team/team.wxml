<!--pages/team/team.wxml-->
<view class="team-container" bindtap="onContainerTap">
  <!-- 搜索框 -->
  <view class="search-container" catchtap="onSearchTap">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="{{searchPlaceholder}}"
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
        value="{{searchQuery}}"
        focus="{{isApplyMode}}"
      />
    </view>
  </view>

  <!-- 团队统计 -->
  <view class="team-stats-section">
    <view class="team-stat-item">
      <text class="team-stat-number">{{teamCount}}</text>
      <text class="team-stat-label">联合创始人</text>
    </view>
    <view class="team-stat-item team-stat-border">
      <text class="team-stat-number">{{totalBadges}}</text>
      <text class="team-stat-label">荣誉徽章</text>
    </view>
    <view class="team-stat-item">
      <text class="team-stat-number">{{uniqueSkills}}</text>
      <text class="team-stat-label">专业技能</text>
    </view>
  </view>

  <!-- 合伙人网格 -->
  <view class="partners-grid">
    <view class="partner-item" wx:for="{{filteredPartners}}" wx:key="name" bindtap="onPartnerTap" data-name="{{item.name}}">
      <view class="partner-avatar {{!item.loaded ? 'partner-avatar-loading' : 'partner-avatar-loaded'}}">
        <view class="partner-avatar-img-wrapper">
          <image class="partner-avatar-img {{item.loaded ? 'partner-avatar-img-show' : ''}}" src="{{item.image}}" mode="aspectFill"></image>
        </view>
      </view>
      <view class="partner-info">
        <text class="partner-name">{{item.name}}</text>
        <view class="partner-school-container">
          <text class="partner-school" wx:for="{{item.schoolLines}}" wx:key="*this" wx:for-item="line">{{line}}</text>
        </view>
        <view class="partner-title-container">
          <text class="partner-title" wx:for="{{item.titleLines}}" wx:key="*this" wx:for-item="line">{{line}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加入团队 -->
  <view class="join-section">
    <view class="join-icon">
      <text class="iconfont">🤝</text>
    </view>
    <text class="join-title">善心浙里与您共创丰盛未来！</text>
    <text class="join-desc">以合作互助的态度实现伙伴完美人生</text>
    <text class="join-desc">以专业用心的态度锁住客户幸福生活</text>
    <view class="join-btn" catchtap="onApplyPartner">申请加入团队</view>
  </view>
</view>
