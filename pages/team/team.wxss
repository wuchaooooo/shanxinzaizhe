/* pages/team/team.wxss */
.team-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(194, 0, 0, 0.05);
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #c20000;
}

.back-btn .iconfont {
  font-size: 64rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
  text-align: center;
}

.placeholder {
  width: 80rpx;
}

/* Tab 栏（固定定位，和活动页一致） */
.tabs-fixed-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  background-color: #ffffff;
  border-bottom: 1rpx solid rgba(194, 0, 0, 0.1);
}

.tabs-row {
  display: flex;
  align-items: center;
  height: 128rpx;
}

.search-icon-btn {
  width: 88rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-icon-text {
  font-size: 40rpx;
}

.search-back-icon-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #c20000;
}

.tabs-container {
  flex: 1;
  white-space: nowrap;
  height: 128rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.tabs-container::-webkit-scrollbar {
  display: none;
}

.tabs {
  display: inline-flex;
  gap: 48rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
  height: 100%;
  align-items: center;
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 128rpx;
  flex-shrink: 0;
  position: relative;
  transition: all 0.3s;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 6rpx;
  background-color: #c20000;
  border-radius: 3rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #64748b;
  white-space: nowrap;
}

.tab-active .tab-text {
  color: #0f172a;
}

.expand-btn {
  width: 40rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding-right: 16rpx;
  margin-left: -28rpx;
}

.expand-icon {
  font-size: 24rpx;
  color: #c20000;
}

/* 搜索态搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(194, 0, 0, 0.05);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  flex: 1;
  margin-right: 32rpx;
}

.search-tab-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #c20000;
  white-space: nowrap;
  flex-shrink: 0;
}

.search-divider {
  font-size: 24rpx;
  color: rgba(194, 0, 0, 0.3);
  margin: 0 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 44rpx;
  line-height: 44rpx;
}

.search-placeholder {
  color: rgba(194, 0, 0, 0.6);
}

/* 展开的全部标签面板 */
.tag-panel {
  position: absolute;
  top: 128rpx;
  left: 0;
  right: 0;
  background-color: #ffffff;
  z-index: 49;
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tag-panel-show {
  max-height: 600rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.tag-item {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  background-color: rgba(194, 0, 0, 0.06);
  font-size: 26rpx;
  color: #64748b;
}

.tag-item-active {
  background-color: #c20000;
  color: #ffffff;
}

/* 团队统计 */
.team-stats-section {
  margin-top: 152rpx; /* 128rpx tab栏 + 24rpx 间距 */
  margin-left: 16rpx;
  margin-right: 16rpx;
  margin-bottom: 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  position: relative;
}

.team-stats-content {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  text-align: center;
}

.team-stats-content-no-button {
  padding-bottom: 64rpx;
}

.team-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.team-stat-border {
  border-left: 1rpx solid #e2e8f0;
  border-right: 1rpx solid #e2e8f0;
}

.team-stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #c20000;
  line-height: 1.2;
}

.team-stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.stats-footer-image {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  width: 100rpx;
  height: 100rpx;
  z-index: 0;
  opacity: 0.9;
}

.team-stats-poster-btn-skeleton {
  margin: 0 auto 32rpx;
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: fit-content;
  min-width: 240rpx;
  height: 56rpx;
  background: linear-gradient(90deg,
    rgba(194, 0, 0, 0.08) 25%,
    rgba(194, 0, 0, 0.15) 50%,
    rgba(194, 0, 0, 0.08) 75%
  );
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

.team-stats-poster-btn {
  margin: 0 auto 32rpx;
  background-color: #c20000;
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: fit-content;
  min-width: 240rpx;
  height: 56rpx;
  box-shadow: 0 4rpx 16rpx rgba(194, 0, 0, 0.2);
  /* 移除持续动画，改为点击时的反馈 */
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.team-stats-poster-btn-hidden {
  display: none;
}

.team-stats-poster-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(194, 0, 0, 0.3);
}

@keyframes poster-btn-breathing {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 16rpx rgba(194, 0, 0, 0.2);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 8rpx 24rpx rgba(194, 0, 0, 0.3);
  }
}

.poster-btn-icon-wrapper {
  width: 40rpx;
  height: 40rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx;
  flex-shrink: 0;
}

.poster-btn-icon-img {
  width: 100%;
  height: 100%;
}

.poster-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
  white-space: nowrap;
}

/* 合伙人网格 */
.partners-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 48rpx 24rpx;
  padding: 32rpx;
  margin-top: 16rpx;
}

.partner-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  /* 优化：使用 contain 提升渲染性能 */
  contain: layout style paint;
  /* 优化：开启硬件加速 */
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

/* 只在动画时使用 will-change */
.partner-item.item-animating {
  will-change: transform, opacity;
}

/* 渐进式加载动画 */
.partner-item.item-animating {
  opacity: 0;
  transform: scale(0.8);
  animation: partner-appear 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes partner-appear {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }
  60% {
    opacity: 1;
    transform: scale(1.05);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.partner-avatar {
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  background-color: rgba(194, 0, 0, 0.08);
  overflow: hidden;
  position: relative;
  display: block;
  flex-shrink: 0;
  /* 优化：使用 transform 开启硬件加速 */
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

.partner-avatar-img-wrapper {
  position: absolute;
  width: 170rpx;
  height: 218rpx;
  top: 0;
  left: 0;
  background-color: transparent;
}

.partner-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0;
  background-color: transparent;
  /* 移除 transition，减少重排 */
}

.partner-avatar-img-show {
  opacity: 1;
  /* 直接显示，不使用动画 */
}

/* 头像弹跳动画 - 轻微弹跳效果 */
@keyframes avatar-bounce-in {
  0% {
    opacity: 0;
    transform: scale(0.95);
  }
  50% {
    transform: scale(1.03);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 图片加载中的呼吸动画 - 已禁用以避免闪烁 */
.partner-avatar-loading {
  /* animation: breathing-pulse 2s ease-in-out infinite; */
}

@keyframes breathing-pulse {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

/* 图片加载完成后的状态 */
.partner-avatar:not(.partner-avatar-loading) {
  transform: scale(1);
  opacity: 1;
}

/* 图片加载完成的水波纹动画 - 已禁用以避免闪烁 */
.partner-avatar-loaded {
  /* animation: splash-ripple 0.6s ease-out forwards; */
  border: 8rpx solid rgba(255, 255, 255, 0.5);
}

@keyframes splash-ripple {
  0% {
    box-shadow: 0 0 0 4rpx rgba(194, 0, 0, 0.8),
                0 0 0 4rpx rgba(194, 0, 0, 0.4),
                0 0 0 4rpx rgba(194, 0, 0, 0.3);
  }
  30% {
    box-shadow: 0 0 0 4rpx rgba(194, 0, 0, 0.8),
                0 0 0 8rpx rgba(194, 0, 0, 0.3),
                0 0 0 12rpx rgba(194, 0, 0, 0.15);
  }
  60% {
    box-shadow: 0 0 0 4rpx rgba(194, 0, 0, 0.8),
                0 0 0 12rpx rgba(194, 0, 0, 0.15),
                0 0 0 20rpx rgba(194, 0, 0, 0.08);
  }
  100% {
    box-shadow: 0 0 0 4rpx rgba(194, 0, 0, 0.8);
  }
}

/* 骨架屏文字占位符 */
.skeleton-text {
  color: transparent !important;
  background: linear-gradient(90deg,
    rgba(194, 0, 0, 0.08) 25%,
    rgba(194, 0, 0, 0.15) 50%,
    rgba(194, 0, 0, 0.08) 75%
  );
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  user-select: none;
  display: inline-block;
  overflow: hidden;
}

.partner-name.skeleton-text {
  width: 120rpx;
  height: 34rpx;
}

.partner-school.skeleton-text {
  width: 120rpx;
  height: 26rpx;
}

.partner-title.skeleton-text {
  width: 96rpx;
  height: 23rpx;
  padding: 6rpx 12rpx;
  box-sizing: content-box;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.partner-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 100%;
  gap: 2rpx;
}

.partner-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #0f172a;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
  height: 34rpx;
}

.partner-school-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.partner-school {
  font-size: 20rpx;
  color: #64748b;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
  height: 26rpx;
}

.partner-title-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.partner-title {
  font-size: 18rpx;
  color: #c20000;
  font-weight: 500;
  padding: 6rpx 12rpx;
  background-color: rgba(194, 0, 0, 0.1);
  border-radius: 12rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
  height: 23rpx;
}

/* 团队宣言 */
.team-motto-section {
  padding: 64rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 32rpx;
}

.motto-icon {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: rgba(194, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.motto-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f172a;
}

.motto-desc {
  font-size: 28rpx;
  color: #64748b;
  padding: 0 48rpx;
}

/* 团队海报弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
}

.poster-modal-show {
  opacity: 1;
  visibility: visible;
}

.poster-content {
  width: 100%;
  max-height: 90vh;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  will-change: transform;
}

.poster-content-show {
  transform: translateY(0);
}

.poster-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  flex-shrink: 0;
}

.poster-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}

.poster-modal-close {
  font-size: 44rpx;
  color: #94a3b8;
  line-height: 1;
  padding: 8rpx;
}

.poster-scroll-view {
  flex: 1;
  overflow-y: auto;
}

.poster-image-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 40rpx 60rpx;
  min-height: 60vh;
  position: relative;
}

.poster-skeleton {
  width: 100%;
  aspect-ratio: 0.5;
  background: linear-gradient(90deg,
    rgba(194, 0, 0, 0.08) 0%,
    rgba(194, 0, 0, 0.15) 50%,
    rgba(194, 0, 0, 0.08) 100%
  );
  background-size: 200% 100%;
  border-radius: 16rpx;
  overflow: hidden;
  animation: skeleton-pulse 2s ease-in-out infinite;
  opacity: 1;
  pointer-events: none;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

@keyframes skeleton-pulse {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

.poster-skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.5) 50%,
    transparent 100%
  );
  animation: shimmer 1.2s ease-in-out infinite;
}

@keyframes shimmer {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.poster-image {
  width: 100%;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  background-color: transparent;
  position: relative;
  opacity: 0;
  display: block;
}

.poster-image-show {
  animation: image-fade-in 0.4s ease both;
}

@keyframes image-fade-in {
  0% {
    opacity: 0;
    transform: scale(0.98) translateZ(0);
  }
  60% {
    opacity: 1;
    transform: scale(1.02) translateZ(0);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateZ(0);
  }
}

.poster-tip {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  min-height: 34rpx;
  line-height: 34rpx;
  opacity: 1;
  transition: opacity 0.3s ease;
}

.poster-tip-show {
  animation: tip-fade-in 0.3s ease 0.2s both;
}

@keyframes tip-fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.poster-canvas,
.share-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
}

/* 未完善资料的占位项样式 */
.partner-item-incomplete {
  opacity: 0.9;
}

.partner-avatar-incomplete {
  background: linear-gradient(135deg, rgba(194, 0, 0, 0.1) 0%, rgba(194, 0, 0, 0.05) 100%);
  border: 3rpx dashed rgba(194, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.partner-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  color: rgba(194, 0, 0, 0.6);
  font-weight: 300;
  line-height: 1;
}
