/* pages/team/team.wxss */
.team-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(194, 0, 0, 0.05);
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #c20000;
}

.back-btn .iconfont {
  font-size: 64rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
  text-align: center;
}

.placeholder {
  width: 80rpx;
}

/* 搜索框 */
.search-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 32rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid rgba(194, 0, 0, 0.1);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(194, 0, 0, 0.05);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.search-icon {
  font-size: 40rpx;
  color: #c20000;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 56rpx;
  line-height: 56rpx;
}

.search-placeholder {
  color: rgba(194, 0, 0, 0.6);
}

/* 团队统计 */
.team-stats-section {
  padding: 24rpx 32rpx;
  margin-top: 176rpx;
  display: flex;
  justify-content: space-between;
  text-align: center;
  background-color: #ffffff;
  margin-left: 32rpx;
  margin-right: 32rpx;
  margin-bottom: 48rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.team-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.team-stat-border {
  border-left: 1rpx solid #e2e8f0;
  border-right: 1rpx solid #e2e8f0;
}

.team-stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #c20000;
  line-height: 1.2;
}

.team-stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

/* 合伙人网格 */
.partners-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 48rpx 24rpx;
  padding: 32rpx;
  margin-top: 16rpx;
}

.partner-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.partner-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(194, 0, 0, 0.2);
  overflow: hidden;
  background-color: rgba(194, 0, 0, 0.1);
  position: relative;
  display: block;
  flex-shrink: 0;
  transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1),
              border-color 0.8s ease-out,
              box-shadow 0.8s ease-out,
              opacity 0.6s ease-out;
}

.partner-avatar-img-wrapper {
  position: absolute;
  width: 140rpx;
  height: 175rpx;
  top: 0;
  left: 0;
}

.partner-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0;
  transition: opacity 0.5s ease-in-out;
}

.partner-avatar-img-show {
  opacity: 1;
}

/* 图片加载中的呼吸动画 */
.partner-avatar-loading {
  animation: breathing-pulse 2s ease-in-out infinite;
}

@keyframes breathing-pulse {
  0%, 100% {
    transform: scale(0.98);
    border-color: rgba(194, 0, 0, 0.25);
    box-shadow: 0 0 0 0 rgba(194, 0, 0, 0.3);
  }
  50% {
    transform: scale(1.02);
    border-color: rgba(194, 0, 0, 0.6);
    box-shadow: 0 0 0 8rpx rgba(194, 0, 0, 0);
  }
}

/* 图片加载完成后的状态 */
.partner-avatar:not(.partner-avatar-loading) {
  transform: scale(1);
  opacity: 1;
}

/* 图片加载完成的水波纹动画 */
.partner-avatar-loaded {
  animation: splash-ripple 0.6s ease-out;
}

@keyframes splash-ripple {
  0% {
    box-shadow: 0 0 0 0 rgba(194, 0, 0, 0.4),
                0 0 0 0 rgba(194, 0, 0, 0.3),
                0 0 0 0 rgba(194, 0, 0, 0.15);
    transform: scale(0.97);
  }
  30% {
    box-shadow: 0 0 0 4rpx rgba(194, 0, 0, 0.3),
                0 0 0 8rpx rgba(194, 0, 0, 0.15),
                0 0 0 12rpx rgba(194, 0, 0, 0.08);
    transform: scale(1.03);
  }
  60% {
    box-shadow: 0 0 0 8rpx rgba(194, 0, 0, 0.15),
                0 0 0 16rpx rgba(194, 0, 0, 0.08),
                0 0 0 24rpx rgba(194, 0, 0, 0);
    transform: scale(1);
  }
  100% {
    box-shadow: 0 0 0 12rpx rgba(194, 0, 0, 0),
                0 0 0 24rpx rgba(194, 0, 0, 0),
                0 0 0 30rpx rgba(194, 0, 0, 0);
    transform: scale(1);
  }
}

.partner-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 100%;
  gap: 2rpx;
}

.partner-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #0f172a;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.partner-school-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.partner-school {
  font-size: 20rpx;
  color: #64748b;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.partner-title-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.partner-title {
  font-size: 18rpx;
  color: #c20000;
  font-weight: 500;
  padding: 6rpx 12rpx;
  background-color: rgba(194, 0, 0, 0.1);
  border-radius: 12rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 加入团队 */
.join-section {
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 32rpx;
}

.join-icon {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: rgba(194, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.join-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f172a;
}

.join-desc {
  font-size: 28rpx;
  color: #64748b;
  padding: 0 48rpx;
}

.join-btn {
  width: 70%;
  margin: 0 auto;
  height: 112rpx;
  background-color: #c20000;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 32rpx rgba(194, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

