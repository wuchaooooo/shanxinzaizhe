/* pages/badge-select/badge-select.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.badge-list {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.badge-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.badge-option:last-child {
  border-bottom: none;
}

.badge-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background-color: #ffffff;
}

.badge-checkbox-checked {
  background-color: #c20000;
  border-color: #c20000;
}

.badge-check-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

.badge-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.badge-title {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 500;
}

.badge-desc {
  font-size: 24rpx;
  color: #64748b;
}

.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background-color: #ffffff;
  border-top: 1rpx solid rgba(226, 29, 39, 0.1);
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(226, 29, 39, 0.3);
}

.save-btn::after {
  border: none;
}
