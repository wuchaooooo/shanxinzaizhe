<!--pages/events/events.wxml-->
<wxs module="utils">
  var formatTime = function(timeStr) {
    if (!timeStr) return '待定'
    try {
      var date = getDate(timeStr)
      var year = date.getFullYear()
      var month = ('0' + (date.getMonth() + 1)).slice(-2)
      var day = ('0' + date.getDate()).slice(-2)
      var hour = ('0' + date.getHours()).slice(-2)
      var minute = ('0' + date.getMinutes()).slice(-2)
      return year + '-' + month + '-' + day + ' ' + hour + ':' + minute
    } catch (e) {
      return timeStr
    }
  }

  module.exports = {
    formatTime: formatTime
  }
</wxs>

<view class="events-container">
  <!-- 标签页 -->
  <view class="tabs-container">
    <view class="tabs">
      <view
        class="tab-item {{activeTab === item ? 'tab-active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="index"
        bindtap="onTabChange"
        data-tab="{{item}}"
      >
        <text class="tab-text">{{item}}</text>
      </view>
    </view>
    <!-- 创建按钮（仅联合创始人可见） -->
    <view wx:if="{{isCofounder}}" class="create-btn" bindtap="onCreateEvent">
      <text class="create-icon">➕</text>
    </view>
  </view>

  <!-- 活动列表 -->
  <view class="events-list">
    <!-- 骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton-list">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="index">
        <view class="skeleton-image"></view>
        <view class="skeleton-content">
          <view class="skeleton-title"></view>
          <view class="skeleton-text"></view>
          <view class="skeleton-text short"></view>
        </view>
      </view>
    </view>

    <!-- 活动卡片 -->
    <view wx:if="{{!loading && filteredEvents.length > 0}}">
      <view
        class="event-card"
        wx:for="{{filteredEvents}}"
        wx:key="id"
        bindtap="onEventTap"
        data-id="{{item.id}}"
        data-type="{{item.type}}"
      >
        <image
          class="event-image"
          src="{{item.image || '/images/placeholder.png'}}"
          mode="aspectFill"
        ></image>
        <view class="event-content">
          <view class="event-header">
            <view class="event-type-badge event-type-{{item.type === '星享会' ? 'star' : 'lunch'}}">
              <text class="badge-text">{{item.type}}</text>
            </view>
          </view>
          <view class="event-info">
            <view class="info-item">
              <text class="info-icon">👤</text>
              <text class="info-text">{{item.organizer || '待定'}}</text>
            </view>
            <view class="info-item">
              <text class="info-icon">📅</text>
              <text class="info-text">{{utils.formatTime(item.time)}}</text>
            </view>
            <view wx:if="{{item.address}}" class="info-item">
              <text class="info-icon">📍</text>
              <text class="info-text">{{item.address}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && filteredEvents.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无活动</text>
      <text class="empty-desc">敬请期待精彩活动</text>
    </view>
  </view>
</view>
