<!--pages/events/events.wxml-->
<wxs module="utils">
  var formatTime = function(timeStr) {
    if (!timeStr) return '待定'

    try {
      // 手动解析 ISO 8601 格式: "2026-03-09T11:00:00.000Z"
      // 直接使用字符串切片，不进行数字转换
      var month = timeStr.substring(5, 7)  // "03"
      var day = timeStr.substring(8, 10)   // "09"
      var hour = timeStr.substring(11, 13) // "11"
      var minute = timeStr.substring(14, 16) // "00"

      // 转换为东8区（UTC+8）- 需要数字运算
      var hourNum = hour - 0
      hourNum = hourNum + 8

      var dayNum = day - 0
      if (hourNum >= 24) {
        hourNum = hourNum - 24
        dayNum = dayNum + 1
      }

      // 重新格式化为字符串
      var hourStr = hourNum < 10 ? '0' + hourNum : '' + hourNum
      var dayStr = dayNum < 10 ? '0' + dayNum : '' + dayNum

      return month + '月' + dayStr + '日 ' + hourStr + ':' + minute
    } catch (e) {
      return '异常:' + e
    }
  }

  var getStatusClass = function(status) {
    if (status === '即将开始') return 'status-upcoming'
    if (status === '进行中') return 'status-ongoing'
    if (status === '已结束') return 'status-finished'
    return 'status-upcoming'
  }

  module.exports = {
    formatTime: formatTime,
    getStatusClass: getStatusClass
  }
</wxs>

<!-- 开屏动画 -->
<view wx:if="{{showSplash}}" class="splash-overlay {{splashMeltOut ? 'splash-melt' : ''}}" style="padding-bottom: {{splashNavBarHeight}}px">
  <image wx:if="{{splashLogoUrl}}" class="splash-logo {{splashLogoVisible ? 'splash-logo-in' : ''}} {{splashHeartbeat ? 'splash-heartbeat' : ''}}" src="{{splashLogoUrl}}" mode="aspectFit" />
</view>

<view class="events-page">
  <!-- 标签页（固定在顶部）-->
  <view class="tabs-fixed-wrapper">
    <!-- 默认态：搜索图标 + tab -->
    <view wx:if="{{!isSearching}}" class="tabs-row">
      <view class="search-icon-btn" bindtap="onSearchOpen">
        <text class="search-icon-text">🔍</text>
      </view>
      <scroll-view class="tabs-container" scroll-x="{{true}}" show-scrollbar="{{false}}" scroll-with-animation="{{true}}" scroll-left="{{tabScrollLeft}}">
        <view class="tabs">
          <view
            class="tab-item {{activeTab === item ? 'tab-active' : ''}}"
            wx:for="{{tabs}}"
            wx:key="index"
            bindtap="onTabChange"
            data-tab="{{item}}"
          >
            <text class="tab-text">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
    <!-- 搜索态：返回图标 + 搜索框 -->
    <view wx:else class="tabs-row">
      <view class="search-icon-btn" bindtap="onSearchClose">
        <text class="search-back-icon-text">←</text>
      </view>
      <view class="search-box">
        <text class="search-tab-label">{{activeTab}}</text>
        <text class="search-divider">|</text>
        <input
          class="search-input"
          placeholder="搜索活动信息"
          placeholder-class="search-placeholder"
          bindinput="onSearchInput"
          value="{{searchQuery}}"
          focus="{{isSearching}}"
        />
      </view>
    </view>
  </view>

  <!-- 可滚动内容区域 -->
  <view class="events-scroll-container">
    <!-- 活动统计 -->
    <view class="events-stats-section">
      <view class="events-stats-content {{!isCofounder ? 'events-stats-content-no-button' : ''}}">
        <view class="event-stat-item">
          <text class="event-stat-number">{{currentTabInProgress}}</text>
          <text class="event-stat-label">进行中</text>
        </view>
        <view class="event-stat-item event-stat-border">
          <text class="event-stat-number">{{currentTabUpcoming}}</text>
          <text class="event-stat-label">即将开始</text>
        </view>
        <view class="event-stat-item">
          <text class="event-stat-number">{{currentTabFinished}}</text>
          <text class="event-stat-label">已结束</text>
        </view>
      </view>
      <image wx:if="{{aiaFooterUrl}}" class="stats-footer-image" src="{{aiaFooterUrl}}" mode="aspectFit"></image>
      <!-- 联合创始人：创建活动按钮 -->
      <view wx:if="{{isCofounder}}" class="events-create-btn" catchtap="onCreateEvent">
        <view class="create-btn-icon">
          <text class="create-icon">✨</text>
        </view>
        <text class="create-btn-text">创建活动</text>
      </view>
    </view>

    <!-- 活动列表 -->
    <view class="events-content-wrapper">
      <!-- 骨架屏 -->
      <view wx:if="{{loading}}" class="skeleton-waterfall">
        <view class="skeleton-column">
          <view class="skeleton-card">
            <view class="skeleton-image"></view>
            <view class="skeleton-content">
              <view class="skeleton-title"></view>
              <view class="skeleton-text"></view>
            </view>
          </view>
        </view>
        <view class="skeleton-column">
          <view class="skeleton-card">
            <view class="skeleton-image"></view>
            <view class="skeleton-content">
              <view class="skeleton-title"></view>
              <view class="skeleton-text"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 瀑布流布局 -->
      <view wx:if="{{!loading && leftColumn.length + rightColumn.length > 0}}" class="waterfall-container">
        <!-- 左列 -->
        <view class="waterfall-column left-column">
          <view
            class="event-card {{item.animated ? 'card-animating' : (item.image ? 'card-pre-animate' : '')}}"
            style="animation-delay: {{index * 80}}ms"
            wx:for="{{leftColumn}}"
            wx:key="id"
            wx:for-index="index"
            bindtap="onEventTap"
            data-id="{{item.id}}"
            data-type="{{item.type}}"
          >
            <image
              wx:if="{{item.image}}"
              class="event-image {{item.imageLoaded ? 'event-image-loaded' : ''}}"
              src="{{item.image}}"
              mode="widthFix"
              bindload="onImageLoadComplete"
              binderror="onImageError"
              data-id="{{item.id}}"
            ></image>
            <view wx:else class="event-image-skeleton"></view>
            <view class="event-content">
              <view class="event-title-row">
                <text class="event-title">{{item.name || '活动'}}</text>
              </view>
              <view class="event-info">
                <view class="info-item organizer-item">
                  <image wx:if="{{item.organizerData && item.organizerData.avatar}}" class="organizer-avatar-small" src="{{item.organizerData.avatar}}" mode="aspectFill"></image>
                  <text class="info-text">{{item.organizer || '待定'}}</text>
                </view>
                <view class="event-status-badge {{utils.getStatusClass(item.status)}}">
                  <text class="status-text">{{item.status || '待定'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 右列 -->
        <view class="waterfall-column right-column">
          <view
            class="event-card {{item.animated ? 'card-animating' : (item.image ? 'card-pre-animate' : '')}}"
            style="animation-delay: {{index * 80 + 40}}ms"
            wx:for="{{rightColumn}}"
            wx:key="id"
            wx:for-index="index"
            bindtap="onEventTap"
            data-id="{{item.id}}"
            data-type="{{item.type}}"
          >
            <image
              wx:if="{{item.image}}"
              class="event-image {{item.imageLoaded ? 'event-image-loaded' : ''}}"
              src="{{item.image}}"
              mode="widthFix"
              bindload="onImageLoadComplete"
              binderror="onImageError"
              data-id="{{item.id}}"
            ></image>
            <view wx:else class="event-image-skeleton"></view>
            <view class="event-content">
              <view class="event-title-row">
                <text class="event-title">{{item.name || '活动'}}</text>
              </view>
              <view class="event-info">
                <view class="info-item organizer-item">
                  <image wx:if="{{item.organizerData && item.organizerData.avatar}}" class="organizer-avatar-small" src="{{item.organizerData.avatar}}" mode="aspectFill"></image>
                  <text class="info-text">{{item.organizer || '待定'}}</text>
                </view>
                <view class="event-status-badge {{utils.getStatusClass(item.status)}}">
                  <text class="status-text">{{item.status || '待定'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!loading && leftColumn.length + rightColumn.length === 0}}" class="empty-state">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无活动</text>
        <text class="empty-desc">敬请期待精彩活动</text>
      </view>

      <!-- 底部状态 -->
      <view wx:if="{{leftColumn.length + rightColumn.length > 0}}" class="load-more-footer">
        <text wx:if="{{hasMore}}" class="load-more-hint">上滑加载更多</text>
        <text wx:else class="load-more-end">— 已显示全部活动 —</text>
      </view>
    </view>
  </view>
</view>
