<!--pages/events/events.wxml-->
<view class="events-container">
  <!-- 头部横幅 -->
  <view class="events-banner">
    <view class="banner-overlay">
      <text class="banner-icon">🎉</text>
      <text class="banner-title">精彩活动</text>
      <text class="banner-subtitle">即将与您见面</text>
    </view>
  </view>

  <!-- 近期上线卡片 -->
  <view class="coming-soon-card">
    <view class="card-icon">🚀</view>
    <text class="card-title">近期上线</text>
    <text class="card-desc">我们正在精心筹备精彩活动</text>
    <text class="card-desc">敬请期待</text>
  </view>

  <!-- 功能预告 -->
  <view class="features-section">
    <view class="section-title">
      <text class="title-text">即将推出</text>
    </view>
    <view class="features-grid">
      <view class="feature-item">
        <text class="feature-icon">📅</text>
        <text class="feature-name">活动日历</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🎯</text>
        <text class="feature-name">在线报名</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📸</text>
        <text class="feature-name">精彩回顾</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🏆</text>
        <text class="feature-name">活动奖励</text>
      </view>
    </view>
  </view>

  <!-- 联系我们 -->
  <view class="contact-section">
    <view class="contact-card">
      <text class="contact-text">想了解更多活动信息？</text>
      <button class="contact-btn" bindtap="onContact">联系我们</button>
    </view>
  </view>
</view>

