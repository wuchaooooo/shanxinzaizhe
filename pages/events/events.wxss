/* pages/events/events.wxss */
.events-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 头部横幅 */
.events-banner {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  overflow: hidden;
}

.banner-overlay {
  position: relative;
  z-index: 10;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
}

.banner-icon {
  font-size: 120rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 近期上线卡片 */
.coming-soon-card {
  margin: -60rpx 32rpx 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  position: relative;
  z-index: 10;
}

.card-icon {
  font-size: 96rpx;
  margin-bottom: 8rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f172a;
}

.card-desc {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
}

/* 功能预告 */
.features-section {
  margin: 32rpx;
}

.section-title {
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  border-left: 8rpx solid #E21D27;
  padding-left: 24rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.feature-item {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: transform 0.3s ease;
}

.feature-item:active {
  transform: scale(0.95);
}

.feature-icon {
  font-size: 64rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #0f172a;
}

/* 联系我们 */
.contact-section {
  margin: 32rpx;
}

.contact-card {
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(226, 29, 39, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #ffffff;
  text-align: center;
}

.contact-btn {
  background-color: #ffffff;
  color: #E21D27;
  padding: 20rpx 64rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.contact-btn::after {
  border: none;
}

