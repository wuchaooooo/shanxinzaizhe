/* pages/events/events.wxss */
.events-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 标签页 */
.tabs-container {
  position: sticky;
  top: 0;
  z-index: 50;
  background-color: #ffffff;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(226, 29, 39, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.tabs {
  display: flex;
  gap: 48rpx;
  overflow-x: auto;
  flex: 1;
}

.create-btn {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(226, 29, 39, 0.3);
  flex-shrink: 0;
}

.create-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 0 16rpx;
  border-bottom: 6rpx solid transparent;
  transition: all 0.3s;
}

.tab-active {
  border-bottom-color: #E21D27;
}

.tab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #64748b;
  white-space: nowrap;
}

.tab-active .tab-text {
  color: #0f172a;
}

/* 活动列表 */
.events-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 32rpx;
}

/* 骨架屏 */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.skeleton-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.skeleton-image {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

.skeleton-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-title {
  width: 60%;
  height: 40rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-text {
  width: 100%;
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-text.short {
  width: 40%;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 活动卡片 */
.event-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(226, 29, 39, 0.05);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.event-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.event-image {
  width: 100%;
  height: 400rpx;
  background-color: #f5f5f5;
}

.event-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.event-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.event-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.event-type-star {
  background-color: rgba(226, 29, 39, 0.1);
}

.event-type-star .badge-text {
  color: #E21D27;
}

.event-type-lunch {
  background-color: rgba(59, 130, 246, 0.1);
}

.event-type-lunch .badge-text {
  color: #3b82f6;
}

.event-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #64748b;
  font-size: 28rpx;
}

.info-icon {
  font-size: 28rpx;
}

.info-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}

.empty-desc {
  font-size: 28rpx;
  color: #64748b;
}
