/* pages/events/events.wxss */
.events-page {
  width: 100%;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.events-scroll-container {
  margin-top: 128rpx;
  padding-top: 24rpx;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* 搜索框（搜索态复用） */
.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(194, 0, 0, 0.05);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  flex: 1;
  margin-right: 32rpx;
}

.search-tab-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #c20000;
  white-space: nowrap;
  flex-shrink: 0;
}

.search-divider {
  font-size: 24rpx;
  color: rgba(194, 0, 0, 0.3);
  margin: 0 12rpx;
  flex-shrink: 0;
}

.search-icon {
  font-size: 40rpx;
  color: #c20000;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 44rpx;
  line-height: 44rpx;
}

.search-placeholder {
  color: rgba(194, 0, 0, 0.6);
}

/* 活动统计 */
.events-stats-section {
  margin-top: 0;
  margin-left: 16rpx;
  margin-right: 16rpx;
  margin-bottom: 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  position: relative;
}

.events-stats-content {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  text-align: center;
}

.events-stats-content-no-button {
  padding-bottom: 64rpx;
}

.event-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.event-stat-border {
  border-left: 1rpx solid #e2e8f0;
  border-right: 1rpx solid #e2e8f0;
}

.event-stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #c20000;
  line-height: 1.2;
}

.event-stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.stats-footer-image {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  width: 100rpx;
  height: 100rpx;
  z-index: 0;
  opacity: 0.9;
}

/* 创建活动按钮 */
.events-create-btn {
  margin: 0 auto 32rpx;
  padding: 16rpx 32rpx;
  background-color: #c20000;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: fit-content;
  min-width: 240rpx;
  height: 56rpx;
  box-shadow: 0 4rpx 16rpx rgba(194, 0, 0, 0.2);
  transition: all 0.3s ease;
  animation: create-btn-breathing 2s ease-in-out infinite;
}

.events-create-btn:active {
  transform: scale(0.95);
  animation: none;
}

@keyframes create-btn-breathing {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 16rpx rgba(194, 0, 0, 0.2);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 8rpx 24rpx rgba(194, 0, 0, 0.3);
  }
}

.create-btn-icon {
  width: 40rpx;
  height: 40rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx;
  flex-shrink: 0;
}

.create-icon {
  font-size: 24rpx;
  color: #c20000;
}

.create-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  white-space: nowrap;
}

/* 标签页（固定定位）*/
.tabs-fixed-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 40;
  background-color: #ffffff;
  border-bottom: 1rpx solid rgba(194, 0, 0, 0.1);
}

/* 默认态：tab + 搜索图标 */
.tabs-row {
  display: flex;
  align-items: center;
  height: 128rpx;
}

.tabs-container {
  width: calc(100% - 88rpx);
  white-space: nowrap;
  height: 128rpx;
  display: flex;
  align-items: center;
}

.tabs-container::-webkit-scrollbar {
  display: none;
}

.tabs {
  display: inline-flex;
  gap: 48rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
  height: 100%;
  align-items: center;
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 128rpx;
  flex-shrink: 0;
  position: relative;
  transition: all 0.3s;
}

.tab-item:first-child {
  padding-left: 0;
}

.tab-item:last-child {
  padding-right: 0;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 6rpx;
  background-color: #c20000;
  border-radius: 3rpx;
}

.search-icon-btn {
  width: 88rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-icon-text {
  font-size: 40rpx;
}

.search-back-icon-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #c20000;
}

/* 搜索态：搜索框 + 返回按钮 */
.search-row {
  display: flex;
  align-items: center;
  height: 128rpx;
  padding: 0 24rpx;
  gap: 16rpx;
}

.search-cancel-btn {
  flex-shrink: 0;
  padding: 0 8rpx;
}

.search-cancel-text {
  font-size: 28rpx;
  color: #c20000;
  white-space: nowrap;
}

.create-btn {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(226, 29, 39, 0.3);
  flex-shrink: 0;
}

.create-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.tab-active {
  /* underline handled by ::after */
}

.tab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #64748b;
  white-space: nowrap;
}

.tab-active .tab-text {
  color: #0f172a;
}

/* Swiper 容器 - 已移除 */

.events-content-wrapper {
  width: 100%;
  padding-bottom: 40rpx;
}

/* 瀑布流容器 */
.waterfall-container {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 16rpx 16rpx 0;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 骨架屏 */
.skeleton-waterfall {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 16rpx 16rpx 0;
}

.skeleton-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.skeleton-image {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

.skeleton-content {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-title {
  width: 70%;
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-text {
  width: 100%;
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-text.short {
  width: 40%;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 活动卡片图片骨架屏 */
.event-image-skeleton {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 16rpx 16rpx 0 0;
}

/* 活动卡片 */
.event-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 0;
  transition: transform 0.2s ease;
}

/* 图片加载中：卡片隐藏 */
.event-card.card-pre-animate {
  opacity: 0;
}

/* 图片加载完成后弹入动画 */
.event-card.card-animating {
  opacity: 0;
  transform: scale(0.98);
  animation: card-appear 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes card-appear {
  0% {
    opacity: 0;
    transform: scale(0.98);
  }
  60% {
    opacity: 1;
    transform: scale(1.01);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.event-card:active {
  transform: scale(0.98);
}

.event-image {
  width: 100%;
  display: block;
  background-color: #f5f5f5;
  opacity: 0;
  transform: scale(0.98);
}

.event-image-loaded {
  animation: image-appear 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes image-appear {
  0% {
    opacity: 0;
    transform: scale(0.98);
  }
  60% {
    opacity: 1;
    transform: scale(1.01);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.event-content {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.event-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.event-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.4;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.event-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.organizer-item {
  gap: 12rpx;
}

.organizer-avatar-small {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #e2e8f0;
  flex-shrink: 0;
}

.info-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.info-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

/* 活动状态徽章 */
.event-status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  display: inline-block;
  width: fit-content;
}

.status-upcoming {
  background-color: rgba(59, 130, 246, 0.1);
}

.status-upcoming .status-text {
  color: #3b82f6;
}

.status-ongoing {
  background-color: rgba(34, 197, 94, 0.1);
}

.status-ongoing .status-text {
  color: #22c55e;
}

.status-finished {
  background-color: rgba(148, 163, 184, 0.1);
}

.status-finished .status-text {
  color: #94a3b8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}

.empty-desc {
  font-size: 28rpx;
  color: #64748b;
}

/* 底部加载更多 */
.load-more-footer {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 60rpx;
}

.load-more-hint {
  font-size: 24rpx;
  color: #94a3b8;
}

.load-more-end {
  font-size: 24rpx;
  color: #cbd5e1;
}
