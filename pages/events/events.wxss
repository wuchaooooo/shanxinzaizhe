/* pages/events/events.wxss */
.events-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 搜索框 */
.search-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 32rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid rgba(194, 0, 0, 0.1);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(194, 0, 0, 0.05);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.search-icon {
  font-size: 40rpx;
  color: #c20000;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 56rpx;
  line-height: 56rpx;
}

.search-placeholder {
  color: rgba(194, 0, 0, 0.6);
}

/* 活动统计 */
.events-stats-section {
  margin-top: 176rpx;
  margin-left: 32rpx;
  margin-right: 32rpx;
  margin-bottom: 48rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  position: relative;
}

.events-stats-content {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  text-align: center;
}

.event-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.event-stat-border {
  border-left: 1rpx solid #e2e8f0;
  border-right: 1rpx solid #e2e8f0;
}

.event-stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #c20000;
  line-height: 1.2;
}

.event-stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

/* 创建活动按钮 */
.events-create-btn {
  margin: 0 auto 32rpx;
  padding: 16rpx 32rpx;
  background-color: #c20000;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: fit-content;
  min-width: 240rpx;
  box-shadow: 0 4rpx 16rpx rgba(194, 0, 0, 0.2);
  transition: all 0.3s ease;
  animation: create-btn-breathing 2s ease-in-out infinite;
}

.events-create-btn:active {
  transform: scale(0.95);
  animation: none;
}

@keyframes create-btn-breathing {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 16rpx rgba(194, 0, 0, 0.2);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 8rpx 24rpx rgba(194, 0, 0, 0.3);
  }
}

.create-btn-icon {
  width: 40rpx;
  height: 40rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx;
  flex-shrink: 0;
}

.create-icon {
  font-size: 24rpx;
  color: #c20000;
}

.create-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  white-space: nowrap;
}

/* 标签页 */
.tabs-container {
  position: sticky;
  top: 144rpx;
  z-index: 40;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(194, 0, 0, 0.1);
  margin-bottom: 16rpx;
}

.tabs {
  display: flex;
  gap: 48rpx;
  overflow-x: auto;
  justify-content: center;
}

.create-btn {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(226, 29, 39, 0.3);
  flex-shrink: 0;
}

.create-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 0 16rpx;
  border-bottom: 6rpx solid transparent;
  transition: all 0.3s;
}

.tab-active {
  border-bottom-color: #c20000;
}

.tab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #64748b;
  white-space: nowrap;
}

.tab-active .tab-text {
  color: #0f172a;
}

/* 活动列表 */
.events-list {
  padding: 16rpx 16rpx 32rpx;
}

/* 瀑布流容器 */
.waterfall-container {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 骨架屏 */
.skeleton-waterfall {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.skeleton-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.skeleton-image {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

.skeleton-content {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-title {
  width: 70%;
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-text {
  width: 100%;
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-text.short {
  width: 40%;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 活动卡片 */
.event-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 0;
  transition: transform 0.2s ease;
}

.event-card:active {
  transform: scale(0.98);
}

.event-image {
  width: 100%;
  display: block;
  background-color: #f5f5f5;
}

.event-content {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.event-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.info-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.info-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

/* 活动状态徽章 */
.event-status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  display: inline-block;
  width: fit-content;
}

.status-upcoming {
  background-color: rgba(59, 130, 246, 0.1);
}

.status-upcoming .status-text {
  color: #3b82f6;
}

.status-ongoing {
  background-color: rgba(34, 197, 94, 0.1);
}

.status-ongoing .status-text {
  color: #22c55e;
}

.status-finished {
  background-color: rgba(148, 163, 184, 0.1);
}

.status-finished .status-text {
  color: #94a3b8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}

.empty-desc {
  font-size: 28rpx;
  color: #64748b;
}
