/* pages/admin-migrate/admin-migrate.wxss */
.container {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.status-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}

.status-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
  min-width: 100rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-idle {
  color: #999;
}

.status-loading {
  color: #1989fa;
}

.status-migrating {
  color: #ff9800;
}

.status-completed {
  color: #07c160;
}

.status-error {
  color: #ee0a24;
}

.progress-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #eee;
}

.progress-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.value.success {
  color: #07c160;
}

.value.failed {
  color: #ee0a24;
}

progress {
  margin-top: 24rpx;
}

.start-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-bottom: 32rpx;
}

.logs-section {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}

.logs-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.logs-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.logs-container {
  height: 600rpx;
  padding: 24rpx 32rpx;
}

.log-item {
  font-size: 24rpx;
  color: #666;
  line-height: 40rpx;
  margin-bottom: 12rpx;
  font-family: 'Courier New', monospace;
}

.log-empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}
