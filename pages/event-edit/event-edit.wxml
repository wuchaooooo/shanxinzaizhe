<!--pages/event-edit/event-edit.wxml-->
<view class="edit-container">
  <view class="form-section">
    <!-- 活动类型 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">活动类型</text>
        <text class="required">*</text>
      </view>
      <picker
        class="form-picker"
        mode="selector"
        range="{{typeOptions}}"
        value="{{typeOptions.indexOf(formData.type)}}"
        bindchange="onTypeChange"
      >
        <view class="picker-value">{{formData.type}}</view>
      </picker>
    </view>

    <!-- 活动名称 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">活动名称</text>
        <text class="required">*</text>
      </view>
      <input
        class="form-input"
        placeholder="请输入活动名称"
        value="{{formData.name}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 组织者 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">组织者</text>
        <text class="required">*</text>
      </view>
      <view class="form-input-readonly">
        <text class="readonly-text">{{formData.organizer || '当前用户'}}</text>
      </view>
    </view>

    <!-- 活动时间 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">开始时间</text>
        <text class="required">*</text>
      </view>
      <picker
        class="form-picker"
        mode="date"
        bindchange="onDateChange"
      >
        <view class="picker-value">
          {{formData.displayDate || '请选择日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">开始时间</text>
        <text class="required">*</text>
      </view>
      <picker
        class="form-picker"
        mode="time"
        bindchange="onTimeChange"
      >
        <view class="picker-value">
          {{formData.displayTime || '请选择时间'}}
        </view>
      </picker>
    </view>

    <!-- 结束时间 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">结束日期</text>
      </view>
      <picker
        class="form-picker"
        mode="date"
        bindchange="onEndDateChange"
      >
        <view class="picker-value">
          {{formData.displayEndDate || '请选择结束日期（可选）'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">结束时间</text>
      </view>
      <picker
        class="form-picker"
        mode="time"
        bindchange="onEndTimeChange"
      >
        <view class="picker-value">
          {{formData.displayEndTime || '请选择结束时间（可选）'}}
        </view>
      </picker>
    </view>

    <!-- 活动图片 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">活动海报</text>
      </view>
      <view class="image-upload" bindtap="onChooseImage">
        <image
          wx:if="{{formData.image}}"
          class="upload-image"
          src="{{formData.image}}"
          mode="aspectFill"
        ></image>
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">📷</text>
          <text class="upload-text">点击上传图片</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="actions-section">
    <button
      class="save-btn"
      bindtap="onSave"
      disabled="{{saving}}"
    >
      {{saving ? '保存中...' : (isEdit ? '保存修改' : '创建活动')}}
    </button>
  </view>
</view>
