<!--pages/event-edit/event-edit.wxml-->
<view class="edit-container">
  <view class="form-section">
    <!-- 活动类型和组织者 -->
    <view class="form-item-row">
      <view class="form-item-half">
        <view class="form-label">
          <text class="label-text">活动类型</text>
          <text class="required">*</text>
        </view>
        <picker
          wx:if="{{!isEdit}}"
          mode="selector"
          range="{{typeOptions}}"
          value="{{typeOptions.indexOf(formData.type)}}"
          bindchange="onTypeChange"
        >
          <view class="form-picker">
            <text class="picker-text">{{formData.type}}</text>
          </view>
        </picker>
        <view wx:else class="form-input-readonly">
          <text class="readonly-text">{{formData.type}}</text>
        </view>
      </view>

      <view class="form-item-half">
        <view class="form-label">
          <text class="label-text">组织者</text>
          <text class="required">*</text>
        </view>
        <view class="form-input-readonly">
          <text class="readonly-text">{{formData.organizer || '当前用户'}}</text>
        </view>
      </view>
    </view>

    <!-- 活动名称 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">活动名称</text>
        <text class="required">*</text>
      </view>
      <input
        class="form-input"
        placeholder="请输入活动名称"
        value="{{formData.name}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 开始时间 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">开始时间</text>
        <text class="required">*</text>
      </view>
      <view class="time-picker-row">
        <picker
          class="time-picker-half"
          mode="date"
          value="{{formData.displayDate}}"
          bindchange="onDateChange"
        >
          <view class="form-picker">
            <text class="{{formData.displayDate ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayDate || '请选择日期'}}</text>
          </view>
        </picker>
        <picker
          class="time-picker-half"
          mode="time"
          value="{{formData.displayTime}}"
          bindchange="onTimeChange"
        >
          <view class="form-picker">
            <text class="{{formData.displayTime ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayTime || '请选择时间'}}</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 结束时间 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">结束时间</text>
        <text class="required">*</text>
      </view>
      <view class="time-picker-row">
        <picker
          class="time-picker-half"
          mode="date"
          value="{{formData.displayEndDate}}"
          bindchange="onEndDateChange"
        >
          <view class="form-picker">
            <text class="{{formData.displayEndDate ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayEndDate || '请选择日期'}}</text>
          </view>
        </picker>
        <picker
          class="time-picker-half"
          mode="time"
          value="{{formData.displayEndTime}}"
          bindchange="onEndTimeChange"
        >
          <view class="form-picker">
            <text class="{{formData.displayEndTime ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayEndTime || '请选择时间'}}</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 活动地址（销售门诊和销售建设不显示） -->
    <view class="form-item" wx:if="{{formData.type !== '销售门诊' && formData.type !== '销售建设'}}">
      <view class="form-label">
        <text class="label-text">活动地址</text>
      </view>
      <view class="location-picker" bindtap="onChooseLocation">
        <text class="location-text">{{formData.address || '点击选择地址'}}</text>
        <text class="location-icon">📍</text>
      </view>
    </view>

    <!-- 活动签到码（仅星享会、午餐会、客户活动显示） -->
    <view class="form-item" wx:if="{{formData.type === '星享会' || formData.type === '午餐会' || formData.type === '客户活动'}}">
      <view class="form-label">
        <text class="label-text">活动签到码</text>
        <text class="label-hint">（可选）</text>
      </view>
      <view class="checkin-qrcode-upload">
        <!-- 已上传的签到码 -->
        <view class="checkin-qrcode-item" wx:if="{{formData.checkinQrcode}}">
          <image
            class="checkin-qrcode-image"
            src="{{formData.checkinQrcode}}"
            mode="aspectFit"
          ></image>
          <view class="checkin-qrcode-delete" bindtap="onDeleteCheckinQrcode">
            <text class="delete-icon">✕</text>
          </view>
        </view>
        <!-- 上传按钮 -->
        <view
          wx:if="{{!formData.checkinQrcode}}"
          class="checkin-qrcode-upload-btn"
          bindtap="onChooseCheckinQrcode"
        >
          <text class="upload-icon">📷</text>
          <text class="upload-text">上传签到码</text>
        </view>
      </view>
    </view>

    <!-- 活动图片 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">活动海报</text>
        <text class="label-hint">（最多9张）</text>
      </view>
      <view class="images-grid">
        <!-- 已上传的图片 -->
        <view
          class="image-item"
          wx:for="{{formData.images}}"
          wx:key="index"
        >
          <image
            class="upload-image"
            src="{{item}}"
            mode="aspectFill"
          ></image>
          <view class="image-delete" bindtap="onDeleteImage" data-index="{{index}}">
            <text class="delete-icon">✕</text>
          </view>
        </view>
        <!-- 上传按钮 -->
        <view
          wx:if="{{formData.images.length < 9}}"
          class="image-upload"
          bindtap="onChooseImage"
        >
          <text class="upload-icon">📷</text>
          <text class="upload-text">添加图片</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="actions-section">
    <button
      class="save-btn"
      bindtap="onSave"
      disabled="{{saving}}"
    >
      {{saving ? '保存中...' : (isEdit ? '保存修改' : '创建活动')}}
    </button>
  </view>
</view>
