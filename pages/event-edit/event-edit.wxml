<!--pages/event-edit/event-edit.wxml-->
<view class="edit-container">

  <!-- 基本信息 -->
  <text class="card-title">基本信息</text>
  <view class="form-card">

    <!-- 活动类型 + 组织者 -->
    <view class="form-item-row">
      <view class="form-item-half">
        <view class="form-label">
          <text class="label-text">活动类型</text>
          <text class="required">*</text>
        </view>
        <picker
          wx:if="{{!isEdit}}"
          mode="selector"
          range="{{typeOptions}}"
          value="{{typeOptions.indexOf(formData.type)}}"
          bindchange="onTypeChange"
        >
          <view class="form-picker">
            <text class="picker-text">{{formData.type}}</text>
          </view>
        </picker>
        <view wx:else class="form-input-readonly">
          <text class="readonly-text">{{formData.type}}</text>
          <text class="readonly-lock">🔒</text>
        </view>
      </view>

      <view class="form-item-half">
        <view class="form-label">
          <text class="label-text">组织者</text>
          <text class="required">*</text>
        </view>
        <view class="form-input-readonly">
          <text class="readonly-text">{{formData.organizer || '当前用户'}}</text>
          <text class="readonly-lock">🔒</text>
        </view>
      </view>
    </view>

    <!-- 活动名称 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">活动名称</text>
        <text class="required">*</text>
      </view>
      <input
        class="form-input"
        placeholder="请输入活动名称"
        value="{{formData.name}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 活动备注 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">活动备注</text>
        <text class="label-hint">（可选）</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="请输入活动备注"
        value="{{formData.notes}}"
        bindinput="onNotesInput"
        maxlength="500"
        auto-height
      ></textarea>
    </view>
  </view>

  <!-- 活动时间 -->
  <text class="card-title">活动时间</text>
  <view class="form-card">

    <!-- 开始时间 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">开始时间</text>
        <text class="required">*</text>
      </view>
      <view class="time-picker-row">
        <picker class="time-picker-half" mode="date" value="{{formData.displayDate}}" bindchange="onDateChange">
          <view class="form-picker">
            <text class="picker-icon">📅</text>
            <text class="{{formData.displayDate ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayDate || '选择日期'}}</text>
          </view>
        </picker>
        <picker class="time-picker-half" mode="time" value="{{formData.displayTime}}" bindchange="onTimeChange">
          <view class="form-picker">
            <text class="picker-icon">⏰</text>
            <text class="{{formData.displayTime ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayTime || '选择时间'}}</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 结束时间 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">结束时间</text>
        <text class="required">*</text>
      </view>
      <view class="time-picker-row">
        <picker class="time-picker-half" mode="date" value="{{formData.displayEndDate}}" bindchange="onEndDateChange">
          <view class="form-picker">
            <text class="picker-icon">📅</text>
            <text class="{{formData.displayEndDate ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayEndDate || '选择日期'}}</text>
          </view>
        </picker>
        <picker class="time-picker-half" mode="time" value="{{formData.displayEndTime}}" bindchange="onEndTimeChange">
          <view class="form-picker">
            <text class="picker-icon">⏰</text>
            <text class="{{formData.displayEndTime ? 'picker-text' : 'picker-placeholder'}}">{{formData.displayEndTime || '选择时间'}}</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 活动地址（销售门诊和销售建设不显示） -->
  <text class="card-title" wx:if="{{formData.type !== '销售门诊' && formData.type !== '销售建设'}}">活动地址</text>
  <view class="form-card" wx:if="{{formData.type !== '销售门诊' && formData.type !== '销售建设'}}">
    <view class="form-item">
      <view class="location-picker" bindtap="onChooseLocation">
        <text class="location-icon">📍</text>
        <text class="{{formData.address ? 'location-text' : 'location-text-placeholder'}}">{{formData.address || '点击选择活动地址'}}</text>
        <text class="location-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 活动签到码（仅星享会、午餐会、客户活动显示） -->
  <text class="card-title" wx:if="{{formData.type === '星享会' || formData.type === '午餐会' || formData.type === '客户活动'}}">活动签到码</text>
  <view class="form-card" wx:if="{{formData.type === '星享会' || formData.type === '午餐会' || formData.type === '客户活动'}}">
    <view class="form-item">
      <view class="images-grid">
        <view class="image-item" wx:if="{{formData.checkinQrcode}}">
          <image class="upload-image" src="{{formData.checkinQrcode}}" mode="aspectFit"></image>
          <view class="image-delete" bindtap="onDeleteCheckinQrcode">
            <text class="delete-icon">✕</text>
          </view>
        </view>
        <view wx:else class="image-upload" bindtap="onChooseCheckinQrcode">
          <text class="upload-plus">+</text>
          <text class="upload-text">上传签到码</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 活动海报 -->
  <text class="card-title">活动海报</text>
  <view class="form-card">
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">最多9张</text>
        <text class="required">*</text>
      </view>
      <view class="images-grid">
        <view
          class="image-item {{dragging && dragIndex === index ? 'image-item-dragging' : ''}} {{dragging && dropIndex === index && dragIndex !== index ? 'image-item-drop-target' : ''}}"
          wx:for="{{formData.images}}"
          wx:key="index"
          data-index="{{index}}"
          bindlongpress="onImageLongPress"
          catchtouchmove="onImageTouchMove"
          bindtouchend="onImageTouchEnd"
        >
          <image class="upload-image" src="{{item}}" mode="aspectFill"></image>
          <view class="image-delete" bindtap="onDeleteImage" data-index="{{index}}">
            <text class="delete-icon">✕</text>
          </view>
        </view>
        <view wx:if="{{formData.images.length < 9}}" class="image-upload" bindtap="onChooseImage">
          <text class="upload-plus">+</text>
          <text class="upload-text">添加图片</text>
        </view>
      </view>
      <view class="drag-hint">
        <text>☰ 长按图片可拖拽排序</text>
      </view>
    </view>
  </view>

  <!-- 拖拽幽灵图 -->
  <view wx:if="{{dragging}}" class="drag-ghost-view" style="left: {{dragX - 50}}px; top: {{dragY - 50}}px;">
    <image class="drag-ghost-img" src="{{dragImageSrc}}" mode="aspectFill"></image>
  </view>

  <!-- 保存和删除按钮 -->
  <view class="actions-section">
    <view class="actions-buttons">
      <button wx:if="{{isEdit}}" class="delete-btn" bindtap="onDelete">删除</button>
      <button class="save-btn" bindtap="onSave" disabled="{{saving}}">
        {{saving ? '保存中...' : (isEdit ? '保存修改' : '创建活动')}}
      </button>
    </view>
  </view>

</view>
