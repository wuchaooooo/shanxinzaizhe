/* pages/event-edit/event-edit.wxss */
.edit-container {
  background-color: #f4f4f4;
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
}

/* ── 分组卡片 ─────────────────────────────── */
.form-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
  border-left: 6rpx solid #E21D27;
  padding-left: 16rpx;
  margin: 40rpx 0 16rpx;
  display: block;
}

.edit-container > .card-title:first-child {
  margin-top: 8rpx;
}

/* ── 表单项 ───────────────────────────────── */
.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item-row {
  display: flex;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.form-item-half {
  flex: 1;
  min-width: 0;
}

/* ── 标签 ─────────────────────────────────── */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748b;
}

.label-hint {
  font-size: 22rpx;
  color: #cbd5e1;
  margin-left: 8rpx;
}

.required {
  color: #E21D27;
  margin-left: 6rpx;
  font-size: 26rpx;
}

/* ── 输入框 ───────────────────────────────── */
.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #cbd5e1;
}

/* ── 只读字段 ─────────────────────────────── */
.form-input-readonly {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #94a3b8;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  gap: 8rpx;
}

.readonly-text {
  flex: 1;
}

.readonly-lock {
  font-size: 22rpx;
  opacity: 0.5;
}

/* ── 文本域 ───────────────────────────────── */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #0f172a;
  line-height: 1.7;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #cbd5e1;
}

.textarea-counter {
  text-align: right;
  font-size: 22rpx;
  color: #cbd5e1;
  margin-top: 8rpx;
}

/* ── 时间选择器 ───────────────────────────── */
.time-picker-row {
  display: flex;
  gap: 16rpx;
}

.time-picker-half {
  flex: 1;
}

.form-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.picker-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
}

.picker-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #cbd5e1;
}

/* ── 地址选择 ─────────────────────────────── */
.location-picker {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
}

.location-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.location-text {
  font-size: 28rpx;
  color: #0f172a;
  flex: 1;
  word-break: break-all;
  line-height: 1.5;
}

.location-text-placeholder {
  font-size: 28rpx;
  color: #cbd5e1;
  flex: 1;
}

.location-arrow {
  font-size: 28rpx;
  color: #cbd5e1;
  flex-shrink: 0;
}

/* ── 签到码上传 ───────────────────────────── */
.checkin-qrcode-upload {
  display: flex;
  align-items: center;
}

.checkin-qrcode-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #e2e8f0;
}

.checkin-qrcode-image {
  width: 100%;
  height: 100%;
}

.checkin-qrcode-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-qrcode-upload-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background-color: #f8fafc;
  border: 2rpx dashed #e2e8f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.checkin-upload-plus {
  font-size: 48rpx;
  color: #E21D27;
  line-height: 1;
  font-weight: 300;
}

/* ── 图片网格 ─────────────────────────────── */
.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  transition: opacity 0.2s, transform 0.2s;
}

.image-item .upload-image {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
}

.image-upload {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16rpx;
  background-color: #f8fafc;
  border: 2rpx dashed #e2e8f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-plus {
  font-size: 56rpx;
  color: #E21D27;
  line-height: 1;
  font-weight: 300;
}

.upload-text {
  font-size: 22rpx;
  color: #94a3b8;
}

.drag-hint {
  font-size: 22rpx;
  color: #cbd5e1;
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* ── 拖拽排序 ─────────────────────────────── */
.image-item-dragging {
  opacity: 0.25;
  transform: scale(0.93);
}

.image-item-drop-target {
  box-shadow: 0 0 0 3rpx #E21D27;
  transform: scale(1.05);
}

.drag-ghost-view {
  position: fixed;
  width: 100px;
  height: 100px;
  border-radius: 10px;
  overflow: hidden;
  z-index: 9999;
  pointer-events: none;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.3);
  transform: scale(1.08);
}

.drag-ghost-img {
  width: 100%;
  height: 100%;
}

/* ── 底部操作栏 ───────────────────────────── */
.actions-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid #f1f5f9;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 1000;
}

.actions-buttons {
  display: flex;
  gap: 16rpx;
}

.save-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(226, 29, 39, 0.3);
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  opacity: 0.55;
}

.delete-btn {
  width: 160rpx;
  height: 88rpx;
  background: #ffffff;
  color: #ef4444;
  border: 2rpx solid #fecaca;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn::after {
  border: none;
}
