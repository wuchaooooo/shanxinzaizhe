/* pages/event-edit/event-edit.wxss */
.edit-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 表单区域 */
.form-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单项行布局 */
.form-item-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.form-item-half {
  flex: 1;
  min-width: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #0f172a;
}

.label-hint {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 8rpx;
}

.required {
  color: #E21D27;
  margin-left: 8rpx;
  font-size: 28rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #94a3b8;
}

/* 只读输入框 */
.form-input-readonly {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #64748b;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.readonly-text {
  flex: 1;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #0f172a;
  line-height: 1.6;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #94a3b8;
}

/* 选择器 */
.form-picker {
  display: flex;
  align-items: center;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
}

.picker-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #94a3b8;
}

.picker-content {
  display: block;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.picker-value {
  font-size: 28rpx;
  color: #0f172a;
  width: 100%;
  height: 100%;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  pointer-events: none;
}

/* 时间选择器行 */
.time-picker-row {
  display: flex;
  gap: 16rpx;
}

.time-picker-half {
  flex: 1;
}

/* 地址选择 */
.location-picker {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
}

.location-text {
  font-size: 28rpx;
  color: #0f172a;
  flex: 1;
  word-break: break-all;
}

.location-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

/* 图片上传 */
.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-item .upload-image {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-icon {
  font-size: 64rpx;
  opacity: 0.5;
}

.upload-text {
  font-size: 24rpx;
  color: #64748b;
}

/* 签到码上传 */
.checkin-qrcode-upload {
  display: flex;
  align-items: center;
}

.checkin-qrcode-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #e2e8f0;
}

.checkin-qrcode-image {
  width: 100%;
  height: 100%;
}

.checkin-qrcode-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-qrcode-upload-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  border: 2rpx dashed #cbd5e1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

/* 操作按钮 */
.actions-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background-color: #ffffff;
  border-top: 1rpx solid rgba(226, 29, 39, 0.1);
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(226, 29, 39, 0.3);
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  opacity: 0.6;
}
