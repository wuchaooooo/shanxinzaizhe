/* pages/event-edit/event-edit.wxss */
.edit-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 表单区域 */
.form-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #0f172a;
}

.required {
  color: #E21D27;
  margin-left: 8rpx;
  font-size: 28rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.form-input::placeholder {
  color: #94a3b8;
}

/* 选择器 */
.form-picker {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 28rpx;
  color: #0f172a;
  flex: 1;
}

/* 地址选择 */
.location-picker {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.location-text {
  font-size: 28rpx;
  color: #0f172a;
  flex: 1;
  word-break: break-all;
}

.location-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

/* 图片上传 */
.image-upload {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 96rpx;
  opacity: 0.5;
}

.upload-text {
  font-size: 28rpx;
  color: #64748b;
}

/* 操作按钮 */
.actions-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background-color: #ffffff;
  border-top: 1rpx solid rgba(226, 29, 39, 0.1);
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(226, 29, 39, 0.3);
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  opacity: 0.6;
}
