<!-- pages/developer/developer.wxml -->
<view class="dev-container">
  <view class="dev-header">
    <text class="dev-title">🔧 开发者面板</text>
    <text class="dev-subtitle">Developer Panel</text>
  </view>

  <view class="dev-card">
    <text class="dev-label">当前登录账号 OpenID</text>
    <view class="dev-value-box">
      <text class="dev-value" selectable="true">{{openid || '获取中...'}}</text>
    </view>
    <button class="dev-copy-btn" bindtap="onCopyOpenid" wx:if="{{openid}}">复制 OpenID</button>
  </view>

  <view class="dev-card">
    <text class="dev-label">环境信息</text>
    <view class="dev-info-row">
      <text class="dev-info-key">平台</text>
      <text class="dev-info-val">{{systemInfo.platform || '-'}}</text>
    </view>
    <view class="dev-info-row">
      <text class="dev-info-key">微信版本</text>
      <text class="dev-info-val">{{systemInfo.version || '-'}}</text>
    </view>
    <view class="dev-info-row">
      <text class="dev-info-key">基础库版本</text>
      <text class="dev-info-val">{{systemInfo.SDKVersion || '-'}}</text>
    </view>
  </view>

  <button class="dev-back-btn" bindtap="onBack">返回首页</button>
</view>
