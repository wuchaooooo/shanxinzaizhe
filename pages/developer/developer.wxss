/* pages/developer/developer.wxss */
page {
  background-color: #0f0f23;
  min-height: 100vh;
}

.dev-container {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
}

.dev-header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 20rpx;
}

.dev-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #e2e8f0;
  letter-spacing: 2rpx;
}

.dev-subtitle {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.dev-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  backdrop-filter: blur(10px);
}

.dev-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
}

.dev-value-box {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.dev-value {
  display: block;
  font-size: 26rpx;
  color: #38bdf8;
  word-break: break-all;
  font-family: monospace;
  line-height: 1.6;
}

.dev-copy-btn {
  background: linear-gradient(135deg, #0ea5e9, #3b82f6);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
  padding: 20rpx 0;
  width: 100%;
}

.dev-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.dev-info-row:last-child {
  border-bottom: none;
}

.dev-info-key {
  font-size: 26rpx;
  color: #94a3b8;
}

.dev-info-val {
  font-size: 26rpx;
  color: #e2e8f0;
  font-family: monospace;
}

.dev-back-btn {
  background: rgba(255, 255, 255, 0.08);
  color: #94a3b8;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  padding: 24rpx 0;
  width: 100%;
  margin-top: 20rpx;
}
