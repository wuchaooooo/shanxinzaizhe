/* pages/event-detail/event-detail.wxss */
.detail-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 活动图片 */
.image-section {
  position: relative;
  width: 100%;
  height: 600rpx;
}

.event-swiper {
  width: 100%;
  height: 100%;
}

.event-image {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3) 0%, transparent 30%);
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  pointer-events: none;
}

.more-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  pointer-events: auto;
}

.more-icon {
  font-size: 32rpx;
  color: #0f172a;
  font-weight: bold;
  line-height: 1;
}

.type-badge {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
  pointer-events: auto;
}

.type-badge-star {
  background-color: rgba(226, 29, 39, 0.9);
}

.type-badge-star .badge-text {
  color: #ffffff;
}

.type-badge-lunch {
  background-color: rgba(59, 130, 246, 0.9);
}

.type-badge-lunch .badge-text {
  color: #ffffff;
}

.type-badge-clinic {
  background-color: rgba(16, 185, 129, 0.9);
}

.type-badge-clinic .badge-text {
  color: #ffffff;
}

.type-badge-building {
  background-color: rgba(245, 158, 11, 0.9);
}

.type-badge-building .badge-text {
  color: #ffffff;
}

/* 活动信息 */
.info-section {
  padding: 32rpx;
}

/* 活动标题 */
.title-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.event-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f172a;
  line-height: 1.4;
  flex: 1;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.checkin-btn {
  display: flex;
  align-items: center;
  gap: 2rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(194, 0, 0, 0.1);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.checkin-btn:active {
  background-color: rgba(194, 0, 0, 0.2);
  transform: scale(0.95);
}

.checkin-btn-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #c20000;
}

.checkin-btn-arrow {
  font-size: 22rpx;
  color: #c20000;
  font-weight: 500;
}

.status-upcoming {
  background-color: rgba(59, 130, 246, 0.1);
}

.status-upcoming .status-text {
  color: #3b82f6;
}

.status-ongoing {
  background-color: rgba(34, 197, 94, 0.1);
}

.status-ongoing .status-text {
  color: #22c55e;
}

.status-finished {
  background-color: rgba(148, 163, 184, 0.1);
}

.status-finished .status-text {
  color: #64748b;
}

/* 活动简介 */
.description-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.description-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
}

.info-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.info-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.info-icon {
  font-size: 28rpx;
}

.label-text {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
}

.info-value {
  font-size: 28rpx;
  color: #0f172a;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.organizer-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
}

.organizer-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #e2e8f0;
  flex-shrink: 0;
}

/* 活动备注 */
.notes-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.notes-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
}

/* 活动签到 */
.checkin-section {
  padding: 0 32rpx 32rpx;
}

.checkin-qrcode-full {
  width: 100%;
  height: 600rpx;
  border-radius: 24rpx;
  background-color: #f8fafc;
  display: block;
}

/* 地图 */
.map-section {
  padding: 0 32rpx 32rpx;
}

.section-title {
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
  border-left: 6rpx solid #E21D27;
  padding-left: 16rpx;
}

.event-map {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nav-btn {
  margin-top: 24rpx;
  width: 100%;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(226, 29, 39, 0.3);
}

.nav-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

/* 操作按钮 */
/* 操作按钮区域 */
.actions-section {
  padding: 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

/* 主要按钮：生成分享图 */
.primary-btn {
  width: 100%;
  background: linear-gradient(135deg, #E21D27 0%, #B81820 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(226, 29, 39, 0.3);
}

/* 次要操作区域 */
.secondary-actions {
  display: flex;
  gap: 16rpx;
}

.secondary-btn {
  flex: 1;
  background-color: #ffffff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  font-weight: 500;
}

.secondary-btn.delete {
  color: #ef4444;
  border-color: #fecaca;
  background-color: #fef2f2;
}
/* 操作菜单弹窗 */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  z-index: 999;
  transition: background-color 0.3s;
  pointer-events: none;
}

.action-sheet-mask-show {
  background-color: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

.action-sheet-show {
  transform: translateY(0);
}

.action-sheet-header {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e2e8f0;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
}

.action-sheet-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #64748b;
}

.action-sheet-close {
  font-size: 40rpx;
  color: #94a3b8;
  line-height: 1;
  padding: 8rpx;
}

.action-sheet-body {
  background-color: #ffffff;
  padding: 48rpx 32rpx;
}

.action-icons-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  gap: 32rpx;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.action-icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.action-icon-circle:active {
  background-color: #e2e8f0;
  transform: scale(0.95);
}

.action-icon-emoji {
  font-size: 40rpx;
}

.action-icon-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* 海报弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.poster-modal-show {
  opacity: 1;
  visibility: visible;
}

.poster-content {
  width: 100%;
  max-height: 90vh;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.poster-content-show {
  transform: translateY(0);
}

.poster-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  flex-shrink: 0;
}

.poster-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}

.poster-modal-close {
  font-size: 44rpx;
  color: #94a3b8;
  line-height: 1;
  padding: 8rpx;
}

.poster-scroll-view {
  flex: 1;
  overflow-y: auto;
}

.poster-image-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 40rpx 60rpx;
  min-height: 60vh;
  position: relative;
}

.poster-skeleton {
  width: 100%;
  aspect-ratio: 0.65;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.poster-skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.5) 50%,
    transparent 100%
  );
  animation: shimmer 1.2s ease-in-out infinite;
}

@keyframes shimmer {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.poster-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  background-color: transparent;
  position: relative;
  opacity: 0;
}

.poster-image-show {
  animation: image-fade-in 0.4s ease both;
}

@keyframes image-fade-in {
  0% {
    opacity: 0;
    transform: scale(0.98);
  }
  60% {
    opacity: 1;
    transform: scale(1.02);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.poster-tip {
  display: block;
  text-align: center;
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #94a3b8;
  opacity: 0;
  transition: opacity 0.3s;
}

.poster-tip-show {
  opacity: 1;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  opacity: 0;
  pointer-events: none;
  z-index: 0;
}

/* 签到码弹窗 */
.checkin-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
}

.checkin-modal-show {
  opacity: 1;
  visibility: visible;
}

.checkin-modal-content {
  width: 100%;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
}

.checkin-modal-content-show {
  transform: translateY(0);
}

.checkin-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  flex-shrink: 0;
}

.checkin-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}

.checkin-modal-close {
  font-size: 44rpx;
  color: #94a3b8;
  line-height: 1;
  padding: 8rpx;
}

.checkin-modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.checkin-modal-qrcode {
  width: 500rpx;
  height: 500rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.checkin-modal-tip {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
}
