<!--pages/event-detail/event-detail.wxml-->
<wxs module="utils">
  var formatTime = function(timeStr) {
    if (!timeStr) return '待定'

    try {
      // 手动解析 ISO 8601 格式: "2026-03-09T11:00:00.000Z"
      var parts = timeStr.split('T')
      if (parts.length !== 2) return '格式错误'

      var datePart = parts[0]
      var timePart = parts[1].replace('Z', '').split('.')[0]

      var dateComponents = datePart.split('-')
      var timeComponents = timePart.split(':')

      if (dateComponents.length !== 3 || timeComponents.length !== 3) {
        return '解析错误'
      }

      // 使用字符串切片直接提取
      var month = timeStr.substring(5, 7)
      var day = timeStr.substring(8, 10)
      var hour = timeStr.substring(11, 13)
      var minute = timeStr.substring(14, 16)

      // 转换为东8区（UTC+8）
      var hourNum = hour - 0
      hourNum = hourNum + 8

      var dayNum = day - 0
      if (hourNum >= 24) {
        hourNum = hourNum - 24
        dayNum = dayNum + 1
      }

      var hourStr = hourNum < 10 ? '0' + hourNum : '' + hourNum
      var dayStr = dayNum < 10 ? '0' + dayNum : '' + dayNum

      return month + '月' + dayStr + '日 ' + hourStr + ':' + minute
    } catch (e) {
      return '错误'
    }
  }

  var getStatusClass = function(status) {
    if (status === '即将开始') return 'upcoming'
    if (status === '进行中') return 'ongoing'
    if (status === '已结束') return 'finished'
    return 'upcoming'
  }

  module.exports = {
    formatTime: formatTime,
    getStatusClass: getStatusClass
  }
</wxs>

<view class="detail-container" wx:if="{{event}}">
  <!-- 活动图片轮播 -->\n  <view class="image-section">
    <swiper
      class="event-swiper"
      indicator-dots="{{event.images && event.images.length > 1}}"
      indicator-color="rgba(255, 255, 255, 0.5)"
      indicator-active-color="#ffffff"
      autoplay="{{false}}"
      circular="{{true}}"
    >
      <swiper-item wx:for="{{event.images || [event.image]}}" wx:key="index">
        <image
          class="event-image"
          src="{{item || '/images/placeholder.png'}}"
          mode="aspectFill"
          bindtap="onImageTap"
          data-index="{{index}}"
        ></image>
      </swiper-item>
    </swiper>
    <view class="image-overlay">
      <view class="type-badge type-badge-{{event.type === '星享会' ? 'star' : 'lunch'}}">
        <text class="badge-text">{{event.type}}</text>
      </view>
      <!-- 更多按钮 -->
      <view class="more-btn" bindtap="onShowActionSheet">
        <text class="more-icon">⋯</text>
      </view>
    </view>
  </view>

  <!-- 活动信息 -->
  <view class="info-section">
    <!-- 活动标题 -->
    <view class="title-section">
      <text class="event-title">{{event.name || '活动详情'}}</text>
      <view wx:if="{{event.status}}" class="status-badge status-{{utils.getStatusClass(event.status)}}">
        <text class="status-text">{{event.status}}</text>
      </view>
    </view>

    <!-- 活动简介 -->
    <view wx:if="{{event.description}}" class="description-section">
      <text class="description-text">{{event.description}}</text>
    </view>

    <view class="info-card">
      <view class="info-row">
        <view class="info-label">
          <text class="info-icon">👤</text>
          <text class="label-text">组织者</text>
        </view>
        <text class="info-value">{{event.organizer || '待定'}}</text>
      </view>

      <view class="info-row">
        <view class="info-label">
          <text class="info-icon">📅</text>
          <text class="label-text">活动时间</text>
        </view>
        <text class="info-value">{{utils.formatTime(event.time)}}</text>
      </view>

      <view wx:if="{{event.address}}" class="info-row">
        <view class="info-label">
          <text class="info-icon">📍</text>
          <text class="label-text">活动地址</text>
        </view>
        <text class="info-value">{{event.address}}</text>
      </view>
    </view>
  </view>

  <!-- 地图 -->
  <view wx:if="{{event.latitude && event.longitude}}" class="map-section">
    <view class="section-title">
      <text class="title-text">活动地点</text>
    </view>
    <map
      id="eventMap"
      class="event-map"
      longitude="{{event.longitude}}"
      latitude="{{event.latitude}}"
      markers="{{markers}}"
      scale="16"
      show-location
    ></map>
    <button class="nav-btn" bindtap="onNavigate">
      <text class="btn-icon">🧭</text>
      <text class="btn-text">导航到活动地点</text>
    </button>
  </view>
</view>

<!-- 操作菜单弹窗 -->
<view class="action-sheet-mask {{showActionSheet ? 'action-sheet-mask-show' : ''}}" bindtap="onHideActionSheet"></view>
<view class="action-sheet {{showActionSheet ? 'action-sheet-show' : ''}}">
  <view class="action-sheet-header">
    <text class="action-sheet-title">更多操作</text>
    <text class="action-sheet-close" bindtap="onHideActionSheet">✕</text>
  </view>
  <view class="action-sheet-body">
    <view class="action-icons-row">
      <view class="action-icon-item" bindtap="onShare">
        <view class="action-icon-circle">
          <text class="action-icon-emoji">📤</text>
        </view>
        <text class="action-icon-label">分享</text>
      </view>
      <view wx:if="{{canEdit}}" class="action-icon-item" bindtap="onEdit">
        <view class="action-icon-circle">
          <text class="action-icon-emoji">✏️</text>
        </view>
        <text class="action-icon-label">编辑</text>
      </view>
      <view wx:if="{{canEdit}}" class="action-icon-item" bindtap="onDelete">
        <view class="action-icon-circle danger">
          <text class="action-icon-emoji">🗑️</text>
        </view>
        <text class="action-icon-label danger">删除</text>
      </view>
    </view>
  </view>
</view>

<!-- 海报弹窗 -->
<view class="poster-modal {{showPoster ? 'poster-modal-show' : ''}}" bindtap="onClosePoster">
  <view class="poster-content {{showPoster ? 'poster-content-show' : ''}}" catchtap="">
    <view class="poster-modal-header">
      <text class="poster-modal-title">活动海报</text>
      <text class="poster-modal-close" bindtap="onClosePoster">✕</text>
    </view>
    <scroll-view class="poster-scroll-view" scroll-y>
      <view class="poster-image-wrapper">
        <!-- 骨架屏 -->
        <view class="poster-skeleton {{posterImage ? 'poster-skeleton-hide' : ''}}">
          <view class="poster-skeleton-shimmer"></view>
        </view>
        <!-- 真实海报 -->
        <image class="poster-image {{posterImage ? 'poster-image-show' : ''}}" src="{{posterImage}}" mode="widthFix" show-menu-by-longpress="{{true}}"></image>
        <!-- 提示文字 -->
        <text class="poster-tip poster-tip-show" wx:if="{{posterImage}}">长按图片保存到相册</text>
      </view>
    </scroll-view>
  </view>
</view>

<!-- Canvas 用于生成海报 -->
<canvas canvas-id="posterCanvas" class="poster-canvas" style="width: 750px; height: {{canvasHeight}}px;"></canvas>

<!-- 加载状态 -->
<view wx:if="{{!event}}" class="loading-state">
  <text class="loading-text">加载中...</text>
</view>
