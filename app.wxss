/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #0f172a;
}

/* 全局颜色变量 */
.primary-color {
  color: #c20000;
}

.primary-bg {
  background-color: #c20000;
}

/* 通用容器 */
.container {
  padding: 32rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: #c20000;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-weight: bold;
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
}

/* 文本样式 */
.text-primary {
  color: #c20000;
}

.text-secondary {
  color: #64748b;
}

.text-muted {
  color: #94a3b8;
}

/* 标题样式 */
.title-lg {
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1.2;
}

.title-md {
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.3;
}

.title-sm {
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.4;
}

/* 间距工具类 */
.mt-8 { margin-top: 16rpx; }
.mt-16 { margin-top: 32rpx; }
.mt-24 { margin-top: 48rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-16 { margin-bottom: 32rpx; }
.mb-24 { margin-bottom: 48rpx; }

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

/* 圆角 */
.rounded-full {
  border-radius: 50%;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-xl {
  border-radius: 24rpx;
}
