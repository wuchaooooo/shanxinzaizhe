/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #0f172a;
}

/* 开屏动画（全局） */
.splash-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.splash-logo {
  width: 240rpx;
  height: 240rpx;
  opacity: 0;
  transform: scale(0.85);
  transition: opacity 0.35s ease, transform 0.35s ease;
  display: block;
  flex-shrink: 0;
}

.splash-logo-in {
  opacity: 1;
  transform: scale(1);
}

.splash-heartbeat {
  animation: splash-beat 1.6s ease-in-out forwards;
}

@keyframes splash-beat {
  0%   { transform: scale(1); }
  12%  { transform: scale(1.28); }
  24%  { transform: scale(1); }
  38%  { transform: scale(1.18); }
  50%  { transform: scale(1); }
  100% { transform: scale(1); }
}

.splash-melt {
  animation: splash-melt-out 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes splash-melt-out {
  from { clip-path: circle(120% at 50% 50%); }
  to   { clip-path: circle(0% at 50% 50%); }
}

/* 全局颜色变量 */
.primary-color {
  color: #c20000;
}

.primary-bg {
  background-color: #c20000;
}

/* 通用容器 */
.container {
  padding: 32rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: #c20000;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-weight: bold;
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
}

/* 文本样式 */
.text-primary {
  color: #c20000;
}

.text-secondary {
  color: #64748b;
}

.text-muted {
  color: #94a3b8;
}

/* 标题样式 */
.title-lg {
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1.2;
}

.title-md {
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.3;
}

.title-sm {
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.4;
}

/* 间距工具类 */
.mt-8 { margin-top: 16rpx; }
.mt-16 { margin-top: 32rpx; }
.mt-24 { margin-top: 48rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-16 { margin-bottom: 32rpx; }
.mb-24 { margin-bottom: 48rpx; }

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

/* 圆角 */
.rounded-full {
  border-radius: 50%;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-xl {
  border-radius: 24rpx;
}
